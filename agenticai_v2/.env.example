# เลือก provider: openrouter | gemini | openai | ollama_cloud | openai_compatible
LLM_PROVIDER=ollama_cloud

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# MCP server (mcp_mssql) endpoint
MCP_MSSQL_URL=http://mcp-mssql-v1:8080/mcp

APP_HOST=0.0.0.0
APP_PORT=80
